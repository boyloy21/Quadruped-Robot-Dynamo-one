<?xml version="1.0"?>
<robot name="visual">

    <material name="blue">
        <color rgba="0 0 0.8 1"/>
    </material>
    <material name="green">
        <color rgba="0 0.8 0 1"/>
    </material>
    <material name="red">
        <color rgba="0.8 0 0 1"/>
    </material>
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>
    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>
    <link name="base_robot_link">
        <visual>
            <geometry>
                <mesh filename="file://$(find test_urdf)/meshes/BB2.dae" scale="0.1 0.1 0.1"/>
            </geometry>
        </visual>
    </link>
    <joint name="floating_base" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <parent link="base_link"/>
        <child link="base_robot_link"/>
    </joint>

    <link name="hip">
        <visual>
            <geometry>
                <mesh filename="file://$(find test_urdf)/meshes/Hip.dae" scale="0.1 0.1 0.1"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>
    <joint name="hip_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <parent link="base_robot_link"/>
        <child link="hip"/>
    </joint>
</robot>